# backend: "mock" (default, reads tests/fixtures/mock_incidents.csv) or "databricks"
INCIDENT_TRIAGE_BACKEND=mock

# Databricks (only needed when INCIDENT_TRIAGE_BACKEND=databricks)
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=

# Anthropic (needed for P4 — real triage calls)
ANTHROPIC_API_KEY=
INCIDENT_TRIAGE_MODEL=claude-haiku-4-5

# SMTP (only needed to actually send the digest, --send)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
DIGEST_TO_EMAIL=
